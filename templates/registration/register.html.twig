{% extends 'base.html.twig' %}

{% block title %}Inscription{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card p-4 mt-4">
            <div class="text-center mb-4">
                <i class="bi bi-person-plus" style="font-size: 2.5rem; color: var(--mm-accent);"></i>
                <h1 class="h4 mt-2">Créer un compte</h1>
                <p class="text-muted small mb-0">Rejoignez M-Motors pour déposer vos dossiers</p>
            </div>

            {{ form_errors(registrationForm) }}

            {{ form_start(registrationForm) }}
                <div class="mb-3">
                    {{ form_row(registrationForm.email, {
                        label: 'Email',
                        attr: {class: 'form-control', placeholder: 'vous@exemple.fr'}
                    }) }}
                </div>
                <div class="row">
                    <div class="col mb-3">
                        {{ form_row(registrationForm.nom, {attr: {class: 'form-control'}}) }}
                    </div>
                    <div class="col mb-3">
                        {{ form_row(registrationForm.prenom, {attr: {class: 'form-control'}}) }}
                    </div>
                </div>
                <div class="mb-3">
                    {{ form_row(registrationForm.plainPassword, {
                        label: 'Mot de passe',
                        attr: {class: 'form-control', placeholder: '6 caractères minimum'}
                    }) }}
                </div>
                <div class="mb-3 form-check">
                    {{ form_widget(registrationForm.agreeTerms, {attr: {class: 'form-check-input'}}) }}
                    <label class="form-check-label" for="{{ registrationForm.agreeTerms.vars.id }}">
                        J'accepte les conditions d'utilisation
                    </label>
                </div>

                <button type="submit" class="btn btn-primary w-100 mb-3">
                    <i class="bi bi-check-lg me-1"></i> Créer mon compte
                </button>

                <p class="text-center small text-muted mb-0">
                    Déjà inscrit ?
                    <a href="{{ path('app_login') }}">Connectez-vous</a>
                </p>
            {{ form_end(registrationForm) }}
        </div>
    </div>
</div>
{% endblock %}