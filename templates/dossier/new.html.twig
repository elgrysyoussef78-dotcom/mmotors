{% extends 'base.html.twig' %}

{% block title %}Déposer un dossier{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-lg-6">
        <a href="{{ path('app_voiture_show', {id: vehicule.id}) }}" class="btn btn-link px-0 mb-2"><i class="bi bi-arrow-left me-1"></i>Retour au véhicule</a>

        <div class="card p-4">
            <h1 class="h4 mb-1">Déposer un dossier</h1>
            <p class="text-muted">
                <i class="bi bi-car-front me-1"></i>
                {{ vehicule.marque }} {{ vehicule.modele }} — {{ vehicule.motorisation }}, {{ vehicule.kilometrage }} km
            </p>

            {{ form_start(form) }}
                <div class="mb-3">
                    {{ form_row(form.type, {attr: {class: 'form-select'}}) }}
                </div>

                <div class="mb-3" id="options-location">
                    <label class="form-label">Options (location uniquement)</label>
                    <div class="row g-2">
                        {% for option in form.options %}
                            <div class="col-md-6">
                                <div class="form-check border rounded p-2 ps-4 h-100 d-flex align-items-center">
                                    {{ form_widget(option, {attr: {class: 'form-check-input me-2'}}) }}
                                    {{ form_label(option, null, {label_attr: {class: 'form-check-label mb-0'}}) }}
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                    <small class="text-muted">Ces options ne s'appliquent qu'aux locations.</small>
                </div>

                <button class="btn btn-primary w-100">
                    <i class="bi bi-send me-1"></i> Envoyer ma demande
                </button>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    const typeSelect = document.querySelector('#dossier_type');
    const optionsBlock = document.querySelector('#options-location');

    function toggleOptions() {
        if (typeSelect.value === 'location') {
            optionsBlock.style.display = 'block';
        } else {
            optionsBlock.style.display = 'none';
        }
    }

    if (typeSelect && optionsBlock) {
        toggleOptions();
        typeSelect.addEventListener('change', toggleOptions);
    }
</script>
{% endblock %}