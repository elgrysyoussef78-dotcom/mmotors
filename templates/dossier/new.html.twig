{% extends 'base.html.twig' %}

{% block title %}Déposer un dossier{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-lg-6">
        <a href="{{ path('app_voiture_show', {id: vehicule.id}) }}" class="btn btn-link px-0 mb-2"><i class="bi bi-arrow-left me-1"></i>Retour au véhicule</a>

        <div class="card p-4">
            <h1 class="h4 mb-1">Déposer un dossier</h1>
            <p class="text-muted">
                <i class="bi bi-car-front me-1"></i>
                {{ vehicule.marque }} {{ vehicule.modele }} — {{ vehicule.motorisation }}, {{ vehicule.kilometrage }} km
            </p>

            {{ form_start(form) }}
                <div class="mb-3">
                    {{ form_row(form.type, {attr: {class: 'form-select'}}) }}
                </div>
                <div class="mb-3">
                    {{ form_row(form.options) }}
                    <small class="text-muted">Ces options ne s'appliquent qu'aux locations.</small>
                </div>
                <button class="btn btn-primary w-100">
                    <i class="bi bi-send me-1"></i> Envoyer ma demande
                </button>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}