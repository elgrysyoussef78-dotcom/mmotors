{% extends 'base.html.twig' %}

{% block title %}Dossier #{{ dossier.id }}{% endblock %}

{% block body %}
<a href="{{ path('app_admin_dossiers') }}" class="btn btn-link px-0 mb-2"><i class="bi bi-arrow-left me-1"></i>Retour aux dossiers</a>

<div class="row">
    <div class="col-lg-7">
        <div class="card p-4 mb-4">
            <h1 class="h4 mb-3">Dossier de {{ dossier.user.prenom }} {{ dossier.user.nom }}</h1>
            <table class="table mb-0">
                <tbody>
                    <tr><th style="width:160px;">Véhicule</th><td>{{ dossier.vehicule.marque }} {{ dossier.vehicule.modele }}</td></tr>
                    <tr><th>Type</th><td class="text-capitalize">{{ dossier.type }}</td></tr>
                    <tr><th>Email client</th><td>{{ dossier.user.email }}</td></tr>
                    <tr><th>Date</th><td>{{ dossier.createdAt|date('d/m/Y') }}</td></tr>
                    {% if dossier.options %}
                        <tr><th>Options</th><td>{{ dossier.options }}</td></tr>
                    {% endif %}
                    <tr>
                        <th>Statut</th>
                        <td>
                            {% if dossier.statut == 'valide' %}
                                <span class="badge bg-success">Validé</span>
                            {% elseif dossier.statut == 'refuse' %}
                                <span class="badge bg-danger">Refusé</span>
                            {% else %}
                                <span class="badge bg-warning text-dark">En attente</span>
                            {% endif %}
                        </td>
                    </tr>
                </tbody>
            </table>

            <div class="mt-3">
                <a href="{{ path('app_admin_dossier_valider', {id: dossier.id}) }}" class="btn btn-success"><i class="bi bi-check-lg me-1"></i>Valider</a>
                <a href="{{ path('app_admin_dossier_refuser', {id: dossier.id}) }}" class="btn btn-danger"><i class="bi bi-x-lg me-1"></i>Refuser</a>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card p-4">
            <h2 class="h6 mb-3"><i class="bi bi-files me-1"></i>Documents déposés</h2>
            {% if dossier.documents is empty %}
                <p class="text-muted mb-0">Aucun document déposé par le client.</p>
            {% else %}
                <ul class="list-group list-group-flush">
                    {% for document in dossier.documents %}
                        <li class="list-group-item px-0">
                            <a href="{{ asset('uploads/documents/' ~ document.chemin) }}" target="_blank">
                                <i class="bi bi-file-earmark-text me-2 text-primary"></i>{{ document.nomFichier }}
                            </a>
                            <span class="text-muted small float-end">{{ document.uploadedAt|date('d/m/Y') }}</span>
                        </li>
                    {% endfor %}
                </ul>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}