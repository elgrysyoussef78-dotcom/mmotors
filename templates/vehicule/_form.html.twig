{{ form_start(form, {'attr': {'enctype': 'multipart/form-data'}}) }}
    <div class="row">
        <div class="col-md-6 mb-3">{{ form_row(form.marque, {attr: {class: 'form-control'}}) }}</div>
        <div class="col-md-6 mb-3">{{ form_row(form.modele, {attr: {class: 'form-control'}}) }}</div>
    </div>
    <div class="row">
        <div class="col-md-6 mb-3">{{ form_row(form.motorisation, {attr: {class: 'form-control'}}) }}</div>
        <div class="col-md-6 mb-3">{{ form_row(form.kilometrage, {attr: {class: 'form-control'}}) }}</div>
    </div>
    <div class="row">
        <div class="col-md-6 mb-3">{{ form_row(form.prixAchat, {attr: {class: 'form-control'}}) }}</div>
        <div class="col-md-6 mb-3">{{ form_row(form.prixLocationMois, {attr: {class: 'form-control'}}) }}</div>
    </div>
    <div class="row">
        <div class="col-md-6 mb-3">{{ form_row(form.type, {attr: {class: 'form-select'}}) }}</div>
        <div class="col-md-6 mb-3">{{ form_row(form.statut, {attr: {class: 'form-select'}}) }}</div>
    </div>
    <div class="mb-3">{{ form_row(form.photoFile, {attr: {class: 'form-control'}}) }}</div>
    <button class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>{{ button_label|default('Enregistrer') }}</button>
{{ form_end(form) }}