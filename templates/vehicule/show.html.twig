{% extends 'base.html.twig' %}

{% block title %}{{ vehicule.marque }} {{ vehicule.modele }}{% endblock %}

{% block body %}
<a href="{{ path('app_vehicule_index') }}" class="btn btn-link px-0 mb-2"><i class="bi bi-arrow-left me-1"></i>Retour à
    la liste</a>
<div class="card p-4">
    <h1 class="h4 mb-4">{{ vehicule.marque }} {{ vehicule.modele }}</h1>
    <table class="table">
        <tbody>
            <tr>
                <th style="width:200px;">Motorisation</th>
                <td>{{ vehicule.motorisation }}</td>
            </tr>
            <tr>
                <th>Kilométrage</th>
                <td>{{ vehicule.kilometrage }} km</td>
            </tr>
            <tr>
                <th>Prix achat</th>
                <td>{{ vehicule.prixAchat ? vehicule.prixAchat ~ ' €' : '—' }}</td>
            </tr>
            <tr>
                <th>Loyer / mois</th>
                <td>{{ vehicule.prixLocationMois ? vehicule.prixLocationMois ~ ' €' : '—' }}</td>
            </tr>
            <tr>
                <th>Type</th>
                <td class="text-capitalize">{{ vehicule.type }}</td>
            </tr>
            <tr>
                <th>Statut</th>
                <td class="text-capitalize">{{ vehicule.statut }}</td>
            </tr>
        </tbody>
    </table>
    <a href="{{ path('app_vehicule_edit', {id: vehicule.id}) }}" class="btn btn-primary"><i
            class="bi bi-pencil me-1"></i>Modifier</a>
    <form method="post" action="{{ path('app_vehicule_delete', {id: vehicule.id}) }}" class="d-inline"
        onsubmit="return confirm('Supprimer définitivement ce véhicule ?');">
        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ vehicule.id) }}">
        <button class="btn btn-danger"><i class="bi bi-trash me-1"></i>Supprimer</button>
    </form>
</div>
{% endblock %}