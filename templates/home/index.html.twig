{% extends 'base.html.twig' %}

{% block title %}M-Motors - Nos véhicules{% endblock %}

{% block body %}
<div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Nos véhicules</h1>
    <div class="btn-group" role="group">
        <a href="{{ path('app_home') }}" class="btn btn-sm {{ typeActuel is null ? 'btn-dark' : 'btn-outline-dark' }}">Tous</a>
        <a href="{{ path('app_home', {type: 'achat'}) }}" class="btn btn-sm {{ typeActuel == 'achat' ? 'btn-primary' : 'btn-outline-primary' }}">À vendre</a>
        <a href="{{ path('app_home', {type: 'location'}) }}" class="btn btn-sm {{ typeActuel == 'location' ? 'btn-success' : 'btn-outline-success' }}">En location</a>
    </div>
</div>

{% if vehicules is empty %}
    <div class="alert alert-info">Aucun véhicule disponible pour ce filtre.</div>
{% else %}
    <div class="row g-4">
        {% for vehicule in vehicules %}
            <div class="col-sm-6 col-lg-4">
                <div class="card h-100">
                    <div class="bg-light d-flex align-items-center justify-content-center" style="height: 160px;">
                        {% if vehicule.photo %}
                            <img src="{{ asset('uploads/vehicules/' ~ vehicule.photo) }}" class="img-fluid" style="max-height: 160px;" alt="{{ vehicule.marque }}">
                        {% else %}
                            <i class="bi bi-car-front" style="font-size: 3.5rem; color: #cbd5e1;"></i>
                        {% endif %}
                    </div>
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title mb-0">{{ vehicule.marque }} {{ vehicule.modele }}</h5>
                            {% if vehicule.type == 'achat' %}
                                <span class="badge bg-primary">Achat</span>
                            {% else %}
                                <span class="badge bg-success">Location</span>
                            {% endif %}
                        </div>
                        <p class="card-text text-muted small mb-3">
                            {{ vehicule.motorisation }} · {{ vehicule.kilometrage }} km
                        </p>
                        <div class="mt-auto d-flex justify-content-between align-items-center">
                            <span class="fw-bold">
                                {% if vehicule.type == 'achat' %}
                                    {{ vehicule.prixAchat }} €
                                {% else %}
                                    {{ vehicule.prixLocationMois }} €/mois
                                {% endif %}
                            </span>
                            <a href="{{ path('app_voiture_show', {id: vehicule.id}) }}" class="btn btn-sm btn-primary">Voir</a>
                        </div>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
{% endif %}
{% endblock %}